{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Coven",
  "description": "Coven is a local-first runtime for project-scoped coding-agent harness sessions, append-only events, and a versioned local socket API.",
  "image": "/assets/opencoven-mark.svg",
  "theme": "mint",
  "modeToggle": {
    "default": "dark",
    "options": ["light", "dark"]
  },
  "icons": {
    "library": "lucide"
  },
  "backgroundImage": "/assets/background.png",
  "logo": {
    "light": "/assets/opencoven-black.svg",
    "dark": "/assets/opencoven-white.svg"
  },
  "branding": {
    "colorPalette": {
      "primary": "#9A8ECD",
      "primaryDark": "#7A6DAA",
      "primaryLight": "#C5BDED",
      "primaryVeryLight": "#E8E4F5",
      "accent": "#D4B5FF",
      "accentMuted": "#9D7FBF"
    }
  },
  "fonts": {
    "body": {
      "family": "Fragment Mono"
    },
    "heading": {
      "family": "DM Sans",
      "weight": "700"
    },
    "code": {
      "family": "Fragment Mono",
      "weight": "400"
    }
  },
  "favicon": "/assets/opencoven-mark.svg",
  "metadata": {
    "colorScheme": "light dark",
    "themeColor": "#9A8ECD"
  },
  "colors": {
    "primary": "#9A8ECD",
    "dark": "#7A6DAA",
    "light": "#C5BDED"
  },
  "styling": {
    "colors": {
      "light": {
        "background": "#FAFBFD",
        "border": "#D9D3E8"
      },
      "dark": {
        "background": "#1A1825",
        "border": "#3D3547"
      }
    },
    "codeblocks": {
      "theme": {
        "dark": "min-dark",
        "light": "min-light"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/OpenCoven/coven",
        "icon": "github"
      },
      {
        "label": "Releases",
        "href": "https://github.com/OpenCoven/coven/releases",
        "icon": "package"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/opencoven",
        "icon": "discord"
      }
    ]
  },
  "redirects": [],
  "headings": {
    "searchable": true
  },
  "navigation": {
    "languages": [
      {
        "language": "English",
        "tabs": [
          {
            "tab": "Start",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "index",
                  "GETTING-STARTED",
                  "start/coven-tui",
                  "TROUBLESHOOTING"
                ]
              },
              {
                "group": "Product frame",
                "pages": [
                  "CONCEPTS",
                  "ROADMAP"
                ]
              }
            ]
          },
          {
            "tab": "Runtime",
            "groups": [
              {
                "group": "Architecture",
                "pages": [
                  "ARCHITECTURE",
                  "OPERATIONAL-MODEL",
                  "SAFETY-MODEL",
                  "AUTH"
                ]
              },
              {
                "group": "Sessions and harnesses",
                "pages": [
                  "SESSION-LIFECYCLE",
                  "harnesses/index",
                  "harnesses/codex",
                  "harnesses/claude-code",
                  "harnesses/installing",
                  "harnesses/provider-auth",
                  "HARNESS-ADAPTERS",
                  "FUTURE-HARNESSES"
                ]
              }
            ]
          },
          {
            "tab": "Integrate",
            "groups": [
              {
                "group": "Local API",
                "pages": [
                  "API",
                  "API-CONTRACT",
                  "CLIENT-INTEGRATION"
                ]
              },
              {
                "group": "Clients",
                "pages": [
                  "COMUX-DEMO-LOOP"
                ]
              }
            ]
          },
          {
            "tab": "Reference",
            "groups": [
              {
                "group": "Lookup",
                "pages": [
                  "reference/cli",
                  "reference/api",
                  "GLOSSARY"
                ]
              },
              {
                "group": "Project",
                "pages": [
                  "PRODUCT-SPEC",
                  "reference/changelog"
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
